{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Collaboration Profile",
  "type": "object",
  "required": ["name", "workingStyle", "decisionRules", "privacyBoundaries"],
  "properties": {
    "name": { "type": "string" },
    "workingStyle": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "decisionRules": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "privacyBoundaries": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "defaultReviewQuestions": { "type": "array", "items": { "type": "string" } }
  }
}

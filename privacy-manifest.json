{
  "name": "ai-collab-toolkit",
  "version": "0.1.0",
  "defaultNetwork": "none",
  "telemetry": false,
  "uploadsUserContent": false,
  "readsWholeDisk": false,
  "defaultInterception": false,
  "defaultHookEnforcement": false,
  "commands": {
    "init": {
      "reads": ["bundled templates inside this npm package", "current working directory path"],
      "writes": [
        ".aict/** in the current working directory",
        "CLAUDE.md (only with --tool claude / --tool all)",
        "AGENTS.md (only with --tool codex / --tool all)",
        ".cursor/rules/ai-collab.mdc (only with --tool cursor / --tool all)",
        ".windsurf/rules/ai-collab.md (only with --tool windsurf / --tool all)",
        ".github/copilot-instructions.md (only with --tool copilot / --tool all)",
        ".clinerules (only with --tool cline / --tool all)"
      ],
      "writesNote": "Without --tool, init writes only under .aict/. The tool-specific paths above are written only when --tool <name> or --tool all is passed, and only if the file does not already exist (existing files are skipped, never overwritten). Every write is recorded in .aict/install-manifest.json for --uninstall.",
      "network": "none",
      "destructiveByDefault": false,
      "dryRunSupported": true,
      "uninstallSupported": true
    },
    "doctor basic": {
      "reads": ["stdin text when provided", "--input text when provided", "--input-file path when provided", "built-in synthetic sample otherwise"],
      "writes": [],
      "network": "none",
      "logsPromptText": false,
      "redaction": ["API-key-like tokens", "cookie-like tokens", "local absolute user paths"]
    },
    "demo": {
      "reads": ["built-in synthetic examples"],
      "writes": [],
      "network": "none"
    }
  },
  "globalFlags": {
    "--dry-run": "Preview writes and do not change disk.",
    "--no-network": "Signals offline intent; core commands make no network calls by design. Not a runtime-enforced network sandbox.",
    "--explain": "Print local rule and path reasoning.",
    "--uninstall": "Remove files listed in .aict/install-manifest.json."
  },
  "logs": {
    "defaultLogFile": "none",
    "recordsPromptText": false,
    "recordsApiKeys": false,
    "recordsPrivatePaths": false
  },
  "security": {
    "secretsCheck": "doctor redacts likely secrets and warns about risky material in evidence snippets",
    "releaseRequires": ["changelog", "checksums", "license review", "privacy-manifest review"]
  }
}
